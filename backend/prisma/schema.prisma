// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Felhasznalo {
  felhasznalo_id   Int               @id @default(autoincrement())
  nev              String
  email            String            @unique
  jelszo_hash      String
  szerepkor        String            @default("felhasznalo")
  letrehozva       DateTime          @default(now())
  utazasResztvevok UtazasResztvevo[]
  tokenek          UserAccessToken[]
}

model UserAccessToken {
  token_id       String   @id @default(uuid())
  felhasznalo_id Int
  nev            String
  date_created   DateTime @default(now())
  expiration     DateTime

  felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id])

  @@index([felhasznalo_id])
}

model Helyszin {
  helyszin_id  Int         @id @default(autoincrement())
  orszag       String
  varos        String
  iranyitoszam String?
  utca         String
  hazszam      String?
  szelesseg    Decimal?    @db.Decimal(10, 7)
  hosszusag    Decimal?    @db.Decimal(10, 7)
  latnivalok   Latnivalo[]
}

model Utazas {
  utazas_id   Int      @id @default(autoincrement())
  nev         String
  leiras      String?
  kezdo_datum DateTime
  veg_datum   DateTime

  resztvevok UtazasResztvevo[]
  programok  Program[]
  foglalasok Foglalas[]
  listak     EllenorzoLista[]
}

model UtazasResztvevo {
  utazas_id         Int
  felhasznalo_id    Int
  szerep            String?
  csatlakozas_ideje DateTime?

  utazas      Utazas      @relation(fields: [utazas_id], references: [utazas_id])
  felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id])

  @@id([utazas_id, felhasznalo_id])
}

model Latnivalo {
  latnivalo_id Int     @id @default(autoincrement())
  helyszin_id  Int
  nev          String
  kategoria    String?
  kep_url      String?
  leiras       String?

  helyszin         Helyszin           @relation(fields: [helyszin_id], references: [helyszin_id])
  programLatnivalo ProgramLatnivalo[]
}

model Program {
  program_id  Int       @id @default(autoincrement())
  utazas_id   Int
  program_nev String
  nap_datum   DateTime?
  letrehozva  DateTime  @default(now())

  utazas     Utazas             @relation(fields: [utazas_id], references: [utazas_id])
  latnivalok ProgramLatnivalo[]
}

model ProgramLatnivalo {
  program_id   Int
  latnivalo_id Int
  tipus        String
  sorrend      Int

  program   Program   @relation(fields: [program_id], references: [program_id])
  latnivalo Latnivalo @relation(fields: [latnivalo_id], references: [latnivalo_id])

  @@id([program_id, latnivalo_id])
}

model Foglalas {
  foglalas_id    Int      @id @default(autoincrement())
  utazas_id      Int
  foglalas_tipus String
  indulasi_hely  String
  erkezesi_hely  String
  indulasi_ido   DateTime
  erkezesi_ido   DateTime
  jaratszam      String?
  letrehozva      DateTime @default(now())
  hely            String?
  cim             String?
  kezdo_datum     DateTime?
  veg_datum       DateTime?

  utazas Utazas @relation(fields: [utazas_id], references: [utazas_id])
}

model EllenorzoLista {
  lista_id  Int    @id @default(autoincrement())
  utazas_id Int
  lista_nev String

  utazas Utazas      @relation(fields: [utazas_id], references: [utazas_id])
  elemek ListaElem[]
}

model ListaElem {
  elem_id    Int     @id @default(autoincrement())
  lista_id   Int
  megnevezes String
  kipipalva  Boolean @default(false)

  lista EllenorzoLista @relation(fields: [lista_id], references: [lista_id])
}
